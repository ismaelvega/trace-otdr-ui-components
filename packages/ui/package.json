{
  "name": "@trace-otdr/ui",
  "version": "1.0.0",
  "description": "UI components and utilities for OTDR SOR data",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": {
      "types": "./dist/css.d.ts",
      "import": "./dist/css.js",
      "require": "./dist/css.cjs"
    },
    "./css/dark": {
      "types": "./dist/css-dark.d.ts",
      "import": "./dist/css-dark.js",
      "require": "./dist/css-dark.cjs"
    },
    "./css/telecom": {
      "types": "./dist/css-telecom.d.ts",
      "import": "./dist/css-telecom.js",
      "require": "./dist/css-telecom.cjs"
    },
    "./web-components": {
      "types": "./dist/web-components/index.d.ts",
      "import": "./dist/web-components/index.js",
      "require": "./dist/web-components/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src tests --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "sor-reader": ">=1.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "sor-reader": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
